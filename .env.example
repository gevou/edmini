# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Optional: For future supervisor/Anthropic track
ANTHROPIC_API_KEY=sk-ant-...

# Supabase ledger (the append-only system of record). Provisioned by infra/supabase/provision.sh,
# which writes the connection string to infra/supabase/project.env. The app/worker need the API
# keys below in .env.local (fetched from the Management API). SERVICE_ROLE is server-side only.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Browser (voice app) reads the public-prefixed pair:
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Discord bus — the edmini bot's token + the #edmini-bus channel id (the app posts outbound as
# the edmini bot). Provisioned/known via infra (infra/hermes/project.env). Put real values in .env.local.
EDMINI_DISCORD_BOT_TOKEN=
EDMINI_BUS_CHANNEL_ID=

# Optional: OpenClaw gateway URL (defaults to http://localhost:18789)
OPENCLAW_URL=http://localhost:18789
# Optional: OpenClaw auth token if gateway auth is enabled
OPENCLAW_TOKEN=
