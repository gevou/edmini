# Required: OpenAI API key with Realtime API access
OPENAI_API_KEY=sk-...

# Optional: For future supervisor/Anthropic track
ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenClaw gateway URL (defaults to http://localhost:18789)
OPENCLAW_URL=http://localhost:18789
# Optional: OpenClaw auth token if gateway auth is enabled
OPENCLAW_TOKEN=
