# edmini Discord bus — config consumed by infra/discord/bootstrap.sh, configure.sh, reset.sh.
# Copy to `project.env` (gitignored). `infra/init.sh` will prompt for the tokens and fill this in.

# ── You provide (irreducible) ───────────────────────────────────────────────
# Two Discord bot tokens. Create both apps at https://discord.com/developers/applications,
# enable the MESSAGE CONTENT INTENT on each, then paste the tokens here.
# Each value may be a raw token OR a 1Password reference, e.g.
#   DISCORD_BOT_TOKEN=op://Private/edmini-hermes-bot/credential
# (init.sh fills these — and creates the 1Password items — automatically.)
DISCORD_BOT_TOKEN=            # the "Hermes" bot (Hermes's identity on Discord)
EDMINI_DISCORD_BOT_TOKEN=     # the "edmini" bot (edmini's worker reads / posts with this)

# Bus channel name (without #). Auto-created by bootstrap.sh.
EDMINI_BUS_CHANNEL=edmini-bus

# Let Hermes read messages from OTHER bots (i.e. from edmini). Required for the bus.
DISCORD_ALLOW_BOTS=true

# ── Auto-filled by bootstrap.sh (leave blank) ───────────────────────────────
EDMINI_GUILD_ID=             # dedicated guild created with the Hermes bot
EDMINI_BUS_CHANNEL_ID=       # the #edmini-bus channel id
