# edmini ledger — Supabase config. Copy to `project.env` (gitignored).
# `infra/init.sh` prompts for the access token; provision.sh auto-creates the project and fills
# in the rest. (Alternatively, skip provisioning and paste an existing SUPABASE_DB_URL directly.)

# ── You provide (irreducible) ───────────────────────────────────────────────
# Supabase Personal Access Token: https://supabase.com/dashboard/account/tokens
# May be a raw token OR a 1Password reference, e.g.
#   SUPABASE_ACCESS_TOKEN=op://Private/edmini-supabase-pat/credential
SUPABASE_ACCESS_TOKEN=

# ── Optional knobs for provisioning ─────────────────────────────────────────
SUPABASE_ORG_ID=             # blank → first org on the account
SUPABASE_REGION=us-east-1
SUPABASE_PROJECT_NAME=edmini-ledger
SUPABASE_DB_PASSWORD=        # blank → generated and saved below

# ── Auto-filled by provision.sh (leave blank) ───────────────────────────────
SUPABASE_PROJECT_REF=
SUPABASE_URL=
SUPABASE_DB_URL=             # session-pooler URI; used by apply.sh / reset.sh (psql)
